{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Windows AppLock",
  "version": "1.0.2",
  "identifier": "com.windows-applock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Windows AppLock",
        "width": 800,
        "height": 600,
        "visible": false,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/RameshXT/AppLock/releases/latest/download/latest.json"
      ],
      "pubkey": "dW51c2VkX3BsYWNlaG9sZGVyX3B1YmtleV9mb3JfZGV2ZWxvcG1lbnRfMTIzNDU2Nzg5MA=="
    }
  }
}
